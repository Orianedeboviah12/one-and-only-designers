# Copy to website/.env.local and adjust.

# Forward contact POSTs from Next to Express (server-side; avoids CORS in the browser).
# Use 127.0.0.1 if "localhost" fails (IPv6 vs IPv4).
CONTACT_UPSTREAM_URL=http://127.0.0.1:3001

# Optional: browser posts directly to this API base (omit to use /api/contact on this site).
# NEXT_PUBLIC_CONTACT_API_BASE_URL=http://127.0.0.1:3001
